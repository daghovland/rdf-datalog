@prefix ex:   <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# People
ex:alice a foaf:Person ; foaf:name "Alice" ; ex:age "30" ; ex:worksFor ex:acme .
ex:bob   a foaf:Person ; foaf:name "Bob"   ; ex:age "25" ; ex:worksFor ex:acme .

# Organisation
ex:acme  a ex:Organisation ; foaf:name "Acme Corp" .

# Knowledge
ex:alice ex:knows ex:bob .

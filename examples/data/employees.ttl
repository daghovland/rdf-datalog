@prefix ex:   <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# OWL subclass axiom: Employee is a subtype of Person
ex:Employee rdfs:subClassOf foaf:Person .

# Carol is an employee — after OWL-RL reasoning, she will also be inferred as a foaf:Person
ex:carol a ex:Employee ; foaf:name "Carol" ; ex:worksFor ex:acme .

# Acme is the employer
ex:acme  a ex:Organisation ; foaf:name "Acme Corp" .

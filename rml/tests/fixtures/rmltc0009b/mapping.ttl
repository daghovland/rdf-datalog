@prefix rml: <http://w3id.org/rml/> .
@prefix ex:  <http://example.com/> .

<http://example.com/TriplesMap>
    a rml:TriplesMap ;
    rml:logicalSource [
        rml:source "city.json" ;
        rml:referenceFormulation rml:JSONPath
    ] ;
    rml:subjectMap [
        rml:template "http://example.com/City/{$.name}"
    ] ;
    rml:predicateObjectMap [
        rml:predicate ex:country ;
        rml:objectMap [ rml:reference "$.country" ] ;
        rml:graphMap [ rml:constant <http://example.com/CityGraph> ]
    ] .

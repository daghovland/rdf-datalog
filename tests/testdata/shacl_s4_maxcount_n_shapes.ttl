# Regression shapes for issue #256 — sh:maxCount N (N > 1) must require N+1
# distinct values to fire a violation, not just 2.
# Source: https://www.w3.org/TR/shacl/#MaxCountConstraintComponent
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX ex: <http://example.com/ns#>

ex:MaxCount2ExampleShape
    a sh:NodeShape ;
    sh:targetNode ex:Dave2, ex:Eve2, ex:Frank2 ;
    sh:property [
        sh:path ex:tag ;
        sh:maxCount 2 ;
    ] .

ex:MaxCount3ExampleShape
    a sh:NodeShape ;
    sh:targetNode ex:Dave3, ex:Eve3, ex:Frank3 ;
    sh:property [
        sh:path ex:tag ;
        sh:maxCount 3 ;
    ] .

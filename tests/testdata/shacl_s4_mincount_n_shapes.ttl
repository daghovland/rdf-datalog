# Regression shapes for issue #256 — sh:minCount N (N > 1) must require at
# least N distinct values, firing when fewer are present (no upper bound).
# Source: https://www.w3.org/TR/shacl/#MinCountConstraintComponent
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX ex: <http://example.com/ns#>

ex:MinCount2ExampleShape
    a sh:NodeShape ;
    sh:targetNode ex:Gina2, ex:Hank2, ex:Ivy2 ;
    sh:property [
        sh:path ex:tag ;
        sh:minCount 2 ;
    ] .

ex:MinCount3ExampleShape
    a sh:NodeShape ;
    sh:targetNode ex:Gina3, ex:Hank3, ex:Ivy3 ;
    sh:property [
        sh:path ex:tag ;
        sh:minCount 3 ;
    ] .

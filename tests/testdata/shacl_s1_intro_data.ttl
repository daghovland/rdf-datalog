# SHACL spec §1.4 — data graph for the introductory PersonShape example.
# Source: https://www.w3.org/TR/shacl/#shacl-example
# This data graph contains three violations when validated against
# shacl_s1_intro_shapes.ttl:
#   - ex:Alice  — ex:ssn does not match the pattern "^\d{3}-\d{2}-\d{4}$"
#   - ex:Bob    — ex:ssn has maxCount 1 but two values are present
#   - ex:Calvin — ex:worksFor value is not an ex:Company (class violation)
#   - ex:Calvin — ex:birthDate is not permitted (sh:closed)
PREFIX ex: <http://example.com/ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ex:Alice
    a ex:Person ;
    ex:ssn "987-65-432A" .

ex:Bob
    a ex:Person ;
    ex:ssn "123-45-6789" ;
    ex:ssn "124-35-6789" .

ex:Calvin
    a ex:Person ;
    ex:birthDate "1971-07-07"^^xsd:date ;
    ex:worksFor ex:UntypedCompany .

{
  "@context": {
    "foaf": "http://xmlns.com/foaf/0.1/",
    "ex":   "http://example.org/",
    "members": {
      "@id":        "ex:member",
      "@container": "@type"
    }
  },
  "@id": "http://example.org/group/1",
  "members": {
    "foaf:Person": [
      { "@id": "http://example.org/alice", "foaf:name": "Alice" },
      { "@id": "http://example.org/bob",   "foaf:name": "Bob"   }
    ]
  }
}

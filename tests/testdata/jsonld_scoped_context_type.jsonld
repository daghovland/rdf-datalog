{
  "@context": {
    "schema": "http://schema.org/",
    "foaf":   "http://xmlns.com/foaf/0.1/",
    "Person": {
      "@id": "foaf:Person",
      "@context": {
        "name":  "foaf:name",
        "email": "foaf:mbox"
      }
    }
  },
  "@graph": [
    {
      "@id":   "http://example.org/alice",
      "@type": "Person",
      "name":  "Alice",
      "email": { "@id": "mailto:alice@example.org" }
    },
    {
      "@id":   "http://example.org/bob",
      "@type": "Person",
      "name":  "Bob"
    }
  ]
}

# SHACL spec §4.5.4 — sh:lessThanOrEquals data graph (LessThanOrEqualsExampleShape).
# Source: https://www.w3.org/TR/shacl/#LessThanOrEqualsConstraintComponent
# ex:Alice startDate = endDate (equal) → satisfies ≤ → conforms.
# ex:Bob   startDate > endDate → 1 violation.
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX ex: <http://example.com/ns#>

ex:Alice
    ex:startDate "2020-06-01"^^xsd:date ;
    ex:endDate   "2020-06-01"^^xsd:date .

ex:Bob
    ex:startDate "2020-06-01"^^xsd:date ;
    ex:endDate   "2020-01-01"^^xsd:date .
